# Apache .htaccess for MUJSTAYS
# Enable URL rewriting, security headers, and restrict access to sensitive folders

Options -Indexes
ServerSignature Off

# ---- Security: Block access to sensitive directories ----
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Block access to KYC uploads
  RewriteRule ^uploads/kyc/ - [F,L]

  # Block access to config and includes
  RewriteRule ^config/ - [F,L]
  RewriteRule ^includes/ - [F,L]
  RewriteRule ^database/ - [F,L]
  RewriteRule ^logs/ - [F,L]
</IfModule>

# ---- Security Headers ----
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---- Deny direct access to PHP files in uploads ----
<FilesMatch "\.(php|php3|php4|php5|phtml|pl|py|jsp|asp|sh|cgi)$">
  <If "%{REQUEST_URI} =~ m|^/MUJSTAYS/uploads/|">
    Order Deny,Allow
    Deny from all
  </If>
</FilesMatch>

# ---- Gzip Compression ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# ---- Browser Caching ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# ---- Custom Error Pages ----
ErrorDocument 403 /MUJSTAYS/index.php
ErrorDocument 404 /MUJSTAYS/index.php
